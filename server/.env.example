# 服务器配置
SERVER_PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_DATABASE=myrpa

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# WebSocket配置
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=35000

# 日志配置
LOG_LEVEL=info
LOG_DIR=logs
